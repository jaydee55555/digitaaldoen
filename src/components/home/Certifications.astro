---
import Container from '@/components/Container.astro';
---

<section id="certifications" class="py-12 bg-surface border-y border-border" data-ps="src/components/home/Certifications.astro:section">
  <Container>
    <div class="flex flex-col items-center gap-8" data-ps="src/components/home/Certifications.astro:layout">
      <div class="text-center" data-ps="src/components/home/Certifications.astro:text-content">
        <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-4" data-ps="src/components/home/Certifications.astro:label">Gecertificeerd in online marketing</p>
        <div class="flex items-center justify-center gap-4 mb-6" data-ps="src/components/home/Certifications.astro:logo-container">
           <img 
            src="https://pagesmith-cdn.com/eb269a49/images/65cf68292e244e1196ba0a57-1536.webp" 
            alt="Certificeringen" 
            class="h-10 md:h-12 w-auto object-contain"
            loading="lazy"
            data-ps="src/components/home/Certifications.astro:img"
          />
        </div>
        <div class="flex items-center justify-center gap-2" data-ps="src/components/home/Certifications.astro:rating">
          <span class="text-xl font-bold" data-ps="src/components/home/Certifications.astro:przgmp">4.8</span>
          <div class="flex text-foreground" data-ps="src/components/home/Certifications.astro:t9txqv">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <span class="text-sm text-muted-foreground ml-1" data-ps="src/components/home/Certifications.astro:przgmo">44 beoordelingen</span>
        </div>
      </div>
    </div>
  </Container>
</section>

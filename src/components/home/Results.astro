---
import Container from '@/components/Container.astro';
---

<section id="results" class="py-24 bg-background" data-ps="src/components/home/Results.astro:section">
  <Container>
    <div class="text-center mb-16 reveal" data-ps="src/components/home/Results.astro:header">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-4" data-ps="src/components/home/Results.astro:title">
        Enkele resultaten van onze partners
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/Results.astro:grid">
      <!-- Result 1 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal" data-ps="src/components/home/Results.astro:result-1">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-1">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/647846dcd15d67c411cc7cc6-768.webp" 
            alt="Resultaat vakman" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-1"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-1">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-1">
            4.147 nieuwe bellers voor een vakman in één jaar met een conversie van 11,11%
          </h3>
        </div>
      </div>

      <!-- Result 2 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal reveal-delay-1" data-ps="src/components/home/Results.astro:result-2">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-2">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/64784760d15d675711cc7cda-768.webp" 
            alt="Resultaat coach" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-2"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-2">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-2">
            124.106 nieuwe inschrijvingen voor een coach op een mailinglijst binnen 18 maanden
          </h3>
        </div>
      </div>

      <!-- Result 3 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal reveal-delay-2" data-ps="src/components/home/Results.astro:result-3">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-3">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/665ebd831848ae459c972cce-1024.webp" 
            alt="Resultaat dienstverlener" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-3"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-3">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-3">
            Lage leadkosten voor een dienstverlener via Google Ads met een conversie van 12,77% naar afspraken
          </h3>
        </div>
      </div>

      <!-- Result 4 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal" data-ps="src/components/home/Results.astro:result-4">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-4">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/665e3c41cfdeb2aac81933ce-1024.webp" 
            alt="Afspraken coach" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-4"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-4">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-4">
            57 nieuwe afspraken in één maand voor een coach, waarvan een mooi deel klant werd
          </h3>
        </div>
      </div>

      <!-- Result 5 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal reveal-delay-1" data-ps="src/components/home/Results.astro:result-5">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-5">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/647847ed99edf53166d814ad-768.webp" 
            alt="Omzet resultaat" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-5"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-5">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-5">
            €740.073,17 omzet in één jaar met een ROAS van 2,27 bij lage productprijzen
          </h3>
        </div>
      </div>

      <!-- Result 6 -->
      <div class="bg-surface rounded-2xl overflow-hidden border border-border flex flex-col reveal reveal-delay-2" data-ps="src/components/home/Results.astro:result-6">
        <div class="p-4 bg-white border-b border-border" data-ps="src/components/home/Results.astro:img-wrapper-6">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/647847ed99edf5f5fcd814ac-768.webp" 
            alt="High ticket sales" 
            class="w-full h-48 object-contain"
            loading="lazy"
            data-ps="src/components/home/Results.astro:img-6"
          />
        </div>
        <div class="p-6 flex-1 flex items-center" data-ps="src/components/home/Results.astro:content-6">
          <h3 class="text-lg font-bold text-foreground leading-snug" data-ps="src/components/home/Results.astro:h3-6">
            Dagelijkse verkopen voor een high ticket product van een coach
          </h3>
        </div>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="services" class="py-24 bg-surface" data-ps="src/components/home/Services.astro:section">
  <Container>
    <div class="max-w-3xl mx-auto text-center mb-16 reveal" data-ps="src/components/home/Services.astro:header">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-6" data-ps="src/components/home/Services.astro:title">
        Zo helpen wij jou aan nieuwe leads en klanten online
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/home/Services.astro:grid">
      <!-- Campagnes -->
      <div class="bg-background p-8 rounded-2xl border border-border shadow-sm hover:shadow-xl transition-all reveal" data-ps="src/components/home/Services.astro:service-1">
        <div class="w-24 h-24 mx-auto mb-8 flex items-center justify-center bg-primary/5 rounded-full" data-ps="src/components/home/Services.astro:icon-container-1">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/665f8450367ebc1ce4c0507a.svg" 
            alt="Campagnes" 
            class="w-16 h-16"
            loading="lazy"
            data-ps="src/components/home/Services.astro:img-1"
          />
        </div>
        <h3 class="text-2xl font-heading font-bold mb-4 text-center" data-ps="src/components/home/Services.astro:h3-1">Campagnes</h3>
        <p class="text-muted-foreground text-center" data-ps="src/components/home/Services.astro:p-1">
          Effectieve campagnes die jouw ideale klanten aantrekken op de grote platformen
        </p>
      </div>

      <!-- Funnels -->
      <div class="bg-background p-8 rounded-2xl border border-border shadow-sm hover:shadow-xl transition-all reveal reveal-delay-1" data-ps="src/components/home/Services.astro:service-2">
        <div class="w-24 h-24 mx-auto mb-8 flex items-center justify-center bg-primary/5 rounded-full" data-ps="src/components/home/Services.astro:icon-container-2">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/665f7dfe1f46ee778a756456-1536.webp" 
            alt="Funnels" 
            class="w-16 h-16 object-contain"
            loading="lazy"
            data-ps="src/components/home/Services.astro:img-2"
          />
        </div>
        <h3 class="text-2xl font-heading font-bold mb-4 text-center" data-ps="src/components/home/Services.astro:h3-2">Funnels</h3>
        <p class="text-muted-foreground text-center" data-ps="src/components/home/Services.astro:p-2">
          Strategisch ontworpen funnels die bezoekers naadloos omzetten in leads en klanten
        </p>
      </div>

      <!-- AI -->
      <div class="bg-background p-8 rounded-2xl border border-border shadow-sm hover:shadow-xl transition-all reveal reveal-delay-2" data-ps="src/components/home/Services.astro:service-3">
        <div class="w-24 h-24 mx-auto mb-8 flex items-center justify-center bg-primary/5 rounded-full" data-ps="src/components/home/Services.astro:icon-container-3">
          <img 
            src="https://pagesmith-cdn.com/eb269a49/images/665f8e148252c45ddb5aa1a0.svg" 
            alt="AI" 
            class="w-16 h-16"
            loading="lazy"
            data-ps="src/components/home/Services.astro:img-3"
          />
        </div>
        <h3 class="text-2xl font-heading font-bold mb-4 text-center" data-ps="src/components/home/Services.astro:h3-3">AI</h3>
        <p class="text-muted-foreground text-center" data-ps="src/components/home/Services.astro:p-3">
          Slimme AI oplossingen die jouw marketing automatiseren en je concurrenten een stap voor blijven
        </p>
      </div>
    </div>

    <div class="mt-16 text-center reveal" data-ps="src/components/home/Services.astro:footer">
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-secondary text-secondary-foreground font-bold rounded-md hover:bg-secondary-hover transition-all no-underline" data-ps="src/components/home/Services.astro:cta">
        Contact opnemen
      </a>
    </div>
  </Container>
</section>
